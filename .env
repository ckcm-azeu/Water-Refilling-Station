################################################################################
# AZEU WATER STATION — ENVIRONMENT CONFIGURATION
# 
# This file contains environment variables for deployment.
# CRITICAL: Keep database credentials and encryption keys secure!
# Never commit this file to version control.
################################################################################

# ══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (TiDBCloud)
# ══════════════════════════════════════════════════════════════════════════════

# TiDBCloud Connection Details
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_NAME=waterstation_db
DB_USER=zJGjwkovwuzEN37.root
DB_PASS=RuIpyygssjzXjB4D

# Enable SSL/TLS for TiDBCloud (REQUIRED - prevents: Connections using insecure transport)
DB_SSL_ENABLED=true

# Optional: If you have a custom SSL CA certificate path
# DB_SSL_CA=/path/to/ca-certificate.pem

################################################################################
# ENCRYPTION CONFIGURATION
################################################################################

# Strong encryption key for AES-256-CBC encryption of user passwords
# Generate with: openssl rand -base64 32
# PRODUCTION: Change this to a secure random key
ENCRYPTION_KEY=your-secure-encryption-key-here-change-in-production

################################################################################
# APPLICATION CONFIGURATION
################################################################################

# Application Environment
APP_ENV=production
APP_DEBUG=false

# System timezone
TIMEZONE=Asia/Manila

# Application URL (auto-set by Render.com, can override here)
APP_URL=https://your-app-name.onrender.com

# Log level in production (ERROR, WARNING, INFO, DEBUG)
LOG_LEVEL=ERROR

################################################################################
# SECURITY & SESSION CONFIGURATION
################################################################################

# Enable/disable password encryption (set to true in production)
ENCRYPT_PASSWORDS=true

# Session timeout in minutes (default 30)
SESSION_TIMEOUT=30

# Enable maintenance mode (blocks all access except admins)
MAINTENANCE_MODE=false

# Maximum failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=10

# Lockout duration in minutes
LOGIN_LOCKOUT_MINUTES=15

################################################################################
# SYSTEM DEFAULTS (Can be changed in admin panel later)
################################################################################

# Station information
STATION_NAME=Azeu Water Station
STATION_ADDRESS=Purok-4 Lapinig, Kapatagan, Lanao del Norte

# Order configuration
DELIVERY_FEE=50.00
MAX_CANCELLATION=5
PENDING_EXPIRY_DAYS=7

# Inventory
LOW_STOCK_THRESHOLD=10

# Features
AUTO_ASSIGN_ORDERS=false
FORCE_DARK_MODE=false

# Color scheme
PRIMARY_COLOR=#1565C0
SECONDARY_COLOR=#1E88E5
ACCENT_COLOR=#42A5F5
SURFACE_COLOR=#F5F7FA

################################################################################
# OPTIONAL: EMAIL CONFIGURATION (For password reset)
################################################################################

# Email service for password reset notifications
# Currently supported: smtp
MAIL_DRIVER=smtp

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
MAIL_FROM=noreply@azeuwater.com
MAIL_FROM_NAME=Azeu Water Station

################################################################################
# IMPORTANT NOTES
################################################################################

# 1. DATABASE SSL/TLS:
#    TiDBCloud requires secure connections. DO NOT set DB_SSL_ENABLED to false
#    Error "Connections using insecure transport are prohibited" indicates SSL not working
#
# 2. ENCRYPTION KEY:
#    Generate a new key for production:
#    $ openssl rand -base64 32
#
# 3. APP_URL:
#    Set to your Render.com deployment URL (e.g., https://azeu-water-station.onrender.com)
#
# 4. SENSITIVE VALUES:
#    Never share DB_PASS, ENCRYPTION_KEY, or SMTP_PASS
#    Use Render.com's environment variable feature for secure storage
#
# 5. DATABASE NAME:
#    Must be created manually in TiDBCloud before deployment
#    Run the SQL script: database_setup_tidbcloud.sql
