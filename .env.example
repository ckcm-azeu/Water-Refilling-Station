# ============================================
# Azeu Water Station - Environment Variables
# ============================================

# --------------------------------------------
# DATABASE CONFIGURATION (TiDBCloud)
# --------------------------------------------
# TiDBCloud connection details
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_NAME=waterstation_db
DB_USER=your_username.root
DB_PASS=your_password_here

# Enable SSL for TiDBCloud (REQUIRED)
DB_SSL_ENABLED=true

# Optional: CA certificate path (usually not needed for TiDBCloud)
# DB_SSL_CA=/path/to/ca-cert.pem

# --------------------------------------------
# SECURITY
# --------------------------------------------
# Generate a strong encryption key (32 characters recommended)
# Use: openssl rand -base64 32
ENCRYPTION_KEY=your_random_32_character_encryption_key_here

# --------------------------------------------
# APPLICATION SETTINGS
# --------------------------------------------
# Set to false in production
DEBUG_MODE=false

# Application timezone
TIMEZONE=Asia/Manila

# Application URL (set by Render automatically)
APP_URL=https://your-app.onrender.com

# --------------------------------------------
# SESSION CONFIGURATION
# --------------------------------------------
SESSION_LIFETIME=3600
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# --------------------------------------------
# LOGGING
# --------------------------------------------
LOG_LEVEL=ERROR
LOG_MAX_SIZE=10485760

# --------------------------------------------
# EMAIL CONFIGURATION (Optional - For Password Reset)
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@azeuwater.com
SMTP_FROM_NAME="Azeu Water Station"
SMTP_ENCRYPTION=tls

# --------------------------------------------
# SYSTEM SETTINGS
# --------------------------------------------
STATION_NAME="Azeu Water Station"
STATION_ADDRESS="Your Station Address Here"
DELIVERY_FEE=50.00
MAX_CANCELLATION=5
PENDING_EXPIRY_DAYS=7
LOW_STOCK_THRESHOLD=10
MAX_LOGIN_ATTEMPTS=10
LOGIN_LOCKOUT_MINUTES=15

# --------------------------------------------
# THEME COLORS (Optional)
# --------------------------------------------
PRIMARY_COLOR=#1565C0
SECONDARY_COLOR=#1E88E5
ACCENT_COLOR=#42A5F5
SURFACE_COLOR=#F5F7FA

# --------------------------------------------
# FEATURES
# --------------------------------------------
MAINTENANCE_MODE=false
ENCRYPT_PASSWORDS=true
AUTO_ASSIGN_ORDERS=false
FORCE_DARK_MODE=false
